# mobile/.env.example
#
# Copy this file to mobile/.env and replace <YOUR_LOCAL_IP> with
# the IP address of the machine running the backend server.
#
# Find your local IP:
#   macOS / Linux:  ip route get 1.1.1.1 | awk '{print $7; exit}'
#                   OR: ifconfig | grep "inet " | grep -v 127.0.0.1
#   Windows:        ipconfig | findstr "IPv4"
#
# The Expo Go app on your phone communicates with the backend over
# your local network, so localhost / 127.0.0.1 will NOT work.
# Use your machine's LAN IP (e.g. 192.168.1.42 or 10.1.0.115).
# For production EAS builds or updates, set EXPO_PUBLIC_API_URL in
# the Expo/EAS environment to your deployed HTTPS API origin.

EXPO_PUBLIC_API_URL=http://<YOUR_LOCAL_IP>:3001
