{
  "name": "site-survey-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "deploy": "EXPO_NO_DOTENV=1 eas update --branch preview --environment preview",
    "deploy-prod": "EXPO_NO_DOTENV=1 eas update --branch main --environment production",
    "build": "EXPO_NO_DOTENV=1 eas build --platform all --environment production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "axios": "^1.14.0",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "@types/uuid": "^10.0.0",
    "eas-cli": "^18.4.0",
    "typescript": "~5.9.2"
  }
}
