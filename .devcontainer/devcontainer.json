{
  "name": "site_survey-app",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "builder"
  },
  "workspaceFolder": "/workspaces/site_survey-app",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "remoteUser": "root",
