{
  "name": "Site Survey App",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces/site_survey-app",

  // Override the compose entrypoint so the container stays up for dev
  "overrideCommand": true,

  "forwardPorts": [3001, 5173, 5432, 8081],
  "portsAttributes": {
    "3001": { "label": "Backend API", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "8081": { "label": "Expo Metro", "onAutoForward": "notify" }
  },

  "postCreateCommand": "npm install --prefix /workspaces/site_survey-app && npm install --prefix /workspaces/site_survey-app/backend && npm install --prefix /workspaces/site_survey-app/frontend",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "bradlc.vscode-tailwindcss",
        "expo.vscode-expo-tools"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib",
        "terminal.integrated.defaultProfile.linux": "sh",
        "terminal.integrated.profiles.linux": {
          "sh": {
            "path": "/bin/sh"
          }
        },
        "terminal.integrated.automationProfile.linux": {
          "path": "/bin/sh"
        }
      }
    }
  },

  "remoteUser": "node"
}
